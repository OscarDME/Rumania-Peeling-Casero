---
// src/components/CarouselSection.astro
import { copy } from "../lib/copy.js";
import { Image } from "astro:assets";
import ba1 from "../assets/before-after-1.webp";
import ba2 from "../assets/before-after-2.webp";
import ba3 from "../assets/before-after-3.webp";
import ba4 from "../assets/before-after-4.webp";

const { carouselSection, a11y } = copy;
const slides = [ba1, ba2, ba3, ba4];
---
<section class="bg-white py-16 md:py-24 px-4 md:px-6" aria-labelledby="carousel-heading">
  <div class="mx-auto max-w-5xl">
    <div class="text-center max-w-2xl mx-auto">
      <p class="uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-3">
        {carouselSection.eyebrow}
      </p>
      <h2 id="carousel-heading" class="text-3xl md:text-5xl font-black leading-tight text-balance text-ink">
        {carouselSection.headline}
      </h2>
      <p class="mt-4 text-base md:text-lg text-ink/70">{carouselSection.subheadline}</p>
    </div>

    <div class="mt-12 relative" data-carousel>
      <div class="overflow-hidden rounded-3xl shadow-soft border border-brand-100/60">
        <div class="flex transition-transform duration-500 ease-out" data-track>
          {slides.map((img, i) => (
            <div class="shrink-0 w-full" data-slide={i}>
              <Image
                src={img}
                alt={carouselSection.headline}
                widths={[480, 768, 1024]}
                sizes="(min-width: 768px) 1024px, 100vw"
                formats={['avif', 'webp']}
                quality={82}
                loading={i === 0 ? "eager" : "lazy"}
                class="w-full h-auto block"
              />
            </div>
          ))}
        </div>
      </div>

      <button
        type="button"
        data-prev
        aria-label={a11y.carouselPrev}
        class="absolute top-1/2 -translate-y-1/2 left-2 md:-left-4 bg-white/90 hover:bg-white text-ink rounded-full w-11 h-11 grid place-items-center shadow-soft border border-brand-100 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-300"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </button>
      <button
        type="button"
        data-next
        aria-label={a11y.carouselNext}
        class="absolute top-1/2 -translate-y-1/2 right-2 md:-right-4 bg-white/90 hover:bg-white text-ink rounded-full w-11 h-11 grid place-items-center shadow-soft border border-brand-100 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-300"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 6l6 6-6 6" />
        </svg>
      </button>

      <div class="mt-5 flex justify-center gap-2" data-dots>
        {slides.map((_, i) => (
          <button
            type="button"
            data-dot={i}
            aria-label={`${a11y.carouselNext} ${i + 1}`}
            class="w-2.5 h-2.5 rounded-full bg-brand-200 data-[active=true]:bg-brand-600 transition-colors"
          ></button>
        ))}
      </div>
    </div>

    <div class="mt-10 text-center">
      <a
        href="#final-cta-section"
        class="inline-block bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-2xl shadow-soft uppercase tracking-wide text-sm md:text-base transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-300"
      >
        {carouselSection.cta}
      </a>
    </div>
  </div>
</section>

<script>
  (function () {
    const root = document.querySelector("[data-carousel]");
    if (!root) return;
    const track = root.querySelector("[data-track]");
    const slides = root.querySelectorAll("[data-slide]");
    const dots = root.querySelectorAll("[data-dot]");
    const total = slides.length;
    let idx = 0;

    function render() {
      track.style.transform = `translateX(-${idx * 100}%)`;
      dots.forEach((d, i) => d.setAttribute("data-active", i === idx ? "true" : "false"));
    }
    render();

    root.querySelector("[data-prev]").addEventListener("click", () => { idx = (idx - 1 + total) % total; render(); });
    root.querySelector("[data-next]").addEventListener("click", () => { idx = (idx + 1) % total; render(); });
    dots.forEach((d) => d.addEventListener("click", () => { idx = Number(d.getAttribute("data-dot")); render(); }));

    let startX = 0;
    track.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) {
        idx = dx < 0 ? (idx + 1) % total : (idx - 1 + total) % total;
        render();
      }
    });

    setInterval(() => { idx = (idx + 1) % total; render(); }, 6000);
  })();
</script>
