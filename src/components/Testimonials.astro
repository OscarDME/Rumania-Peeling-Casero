---
// src/components/Testimonials.astro
import { copy } from "../lib/copy.js";
import { Image } from "astro:assets";
import dep1 from "../assets/depoimento-1.webp";
import dep2 from "../assets/depoimento-2.webp";
import dep3 from "../assets/depoimento-3.webp";

const { testimonials } = copy;
const social = [dep1, dep2, dep3];
---
<section class="bg-white py-16 md:py-24 px-4 md:px-6" aria-labelledby="testimonials-heading">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-3xl mx-auto">
      <p class="uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-3">
        {testimonials.eyebrow}
      </p>
      <h2 id="testimonials-heading" class="text-3xl md:text-5xl font-black leading-tight text-balance text-ink">
        {testimonials.headline}
      </h2>
    </div>

    <ul class="mt-12 grid md:grid-cols-3 gap-5 md:gap-6">
      {testimonials.items.map((t) => (
        <li class="rounded-3xl bg-brand-50/50 border border-brand-100 p-6 md:p-7 shadow-soft">
          <svg class="w-8 h-8 text-brand-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M7 7h4v4H7v6H3v-6c0-2.2 1.8-4 4-4zm10 0h4v4h-4v6h-4v-6c0-2.2 1.8-4 4-4z" />
          </svg>
          <p class="mt-3 text-[16px] md:text-[17px] text-ink/80 leading-relaxed">&ldquo;{t.quote}&rdquo;</p>
          <div class="mt-5 flex items-center gap-3">
            <div class="w-11 h-11 rounded-full bg-brand-600 text-white grid place-items-center font-black">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-ink leading-tight">{t.name}</p>
              <p class="text-xs text-ink/60">{t.role}</p>
            </div>
          </div>
        </li>
      ))}
    </ul>

    <div class="mt-16 text-center">
      <span class="inline-block bg-brand-100 text-brand-700 text-xs font-bold tracking-wider uppercase rounded-full px-4 py-1.5 mb-3">
        {testimonials.socialBadge}
      </span>
      <h3 class="text-2xl md:text-3xl font-black text-ink">{testimonials.socialHeadline}</h3>
    </div>

    <ul class="mt-8 grid md:grid-cols-3 gap-5 md:gap-6">
      {social.map((img) => (
        <li class="rounded-3xl overflow-hidden bg-white border border-brand-100 shadow-soft">
          <Image
            src={img}
            alt={testimonials.socialAlt}
            widths={[320, 480, 640]}
            sizes="(min-width: 768px) 33vw, 100vw"
            formats={['avif', 'webp']}
            quality={82}
            loading="lazy"
            class="w-full h-auto"
          />
        </li>
      ))}
    </ul>
  </div>
</section>
