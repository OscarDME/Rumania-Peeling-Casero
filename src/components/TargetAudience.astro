---
// src/components/TargetAudience.astro
import { copy } from "../lib/copy.js";
import { Image } from "astro:assets";
import imgOpaca from "../assets/pele-opaca.webp";
import imgRugas from "../assets/rugas-profundas.webp";
import imgFlacidez from "../assets/pele-flacidez.webp";
import imgProdutos from "../assets/produtos-falhos.webp";

const { targetAudience } = copy;
const images = [imgOpaca, imgRugas, imgFlacidez, imgProdutos];
---
<section class="bg-brand-50/60 py-16 md:py-24 px-4 md:px-6" aria-labelledby="audience-heading">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto">
      <p class="uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-3">
        {targetAudience.eyebrow}
      </p>
      <h2 id="audience-heading" class="text-3xl md:text-5xl font-black leading-tight text-balance text-ink">
        {targetAudience.headline}
      </h2>
    </div>

    <ul class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      {targetAudience.items.map((item, i) => (
        <li class="group relative rounded-3xl overflow-hidden bg-white border border-brand-100 shadow-soft hover:shadow-glow transition-shadow">
          <div class="aspect-[4/5] overflow-hidden">
            <Image
              src={images[i]}
              alt={item.imageAlt}
              widths={[320, 480, 640]}
              sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
              formats={['avif', 'webp']}
              quality={80}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent pointer-events-none"></div>
          </div>
          <div class="absolute bottom-0 inset-x-0 p-5 md:p-6 text-white">
            <h3 class="text-lg md:text-xl font-extrabold leading-snug">{item.title}</h3>
            <p class="mt-2 text-sm text-white/85 leading-relaxed">{item.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
