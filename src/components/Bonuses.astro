---
// src/components/Bonuses.astro
import { copy } from "../lib/copy.js";
import { Image } from "astro:assets";
import guiaImg from "../assets/peeling-guia.webp";

const { bonuses } = copy;
---
<section class="bg-gradient-to-b from-brand-50/60 to-cream py-16 md:py-24 px-4 md:px-6" aria-labelledby="bonuses-heading">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto">
      <span class="inline-block bg-brand-600 text-white text-xs font-bold tracking-wider uppercase rounded-full px-4 py-1.5 mb-4">
        {bonuses.badge}
      </span>
      <h2 id="bonuses-heading" class="text-3xl md:text-5xl font-black leading-tight text-balance text-ink">
        {bonuses.headline}
      </h2>
      <p class="mt-4 text-base md:text-lg text-ink/70">{bonuses.subheadline}</p>
    </div>

    <div class="mt-12 grid md:grid-cols-5 gap-8 md:gap-10 items-start">
      <div class="md:col-span-2 order-2 md:order-1">
        <Image
          src={guiaImg}
          alt={copy.finalCta.imageAlt}
          widths={[320, 480, 640]}
          sizes="(min-width: 768px) 380px, 80vw"
          formats={['avif', 'webp']}
          quality={82}
          loading="lazy"
          class="w-full max-w-sm mx-auto h-auto drop-shadow-2xl"
        />
      </div>
      <ul class="md:col-span-3 order-1 md:order-2 space-y-4">
        {bonuses.items.map((item, i) => (
          <li class="flex gap-4 rounded-2xl bg-white border border-brand-100/60 p-5 md:p-6 shadow-soft">
            <span class="shrink-0 w-10 h-10 rounded-xl bg-brand-100 text-brand-700 grid place-items-center font-black text-sm">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div>
              <h3 class="text-lg font-extrabold text-ink leading-snug">{item.title}</h3>
              <p class="mt-1 text-[15px] text-ink/70 leading-relaxed">{item.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
