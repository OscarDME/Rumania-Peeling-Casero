---
// src/components/HowItWorks.astro
import { copy } from "../lib/copy.js";
import { Image } from "astro:assets";
import mulherImg from "../assets/mulher-peeling.webp";
import resultImg from "../assets/peeling-resultado.webp";

const { howItWorks } = copy;
---
<section class="bg-white py-16 md:py-24 px-4 md:px-6" aria-labelledby="howitworks-heading">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto">
      <p class="uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-3">
        {howItWorks.eyebrow}
      </p>
      <h2 id="howitworks-heading" class="text-3xl md:text-5xl font-black leading-tight text-balance text-ink">
        {howItWorks.headline}
      </h2>
      <p class="mt-4 text-base md:text-lg text-ink/70">{howItWorks.subheadline}</p>
    </div>

    <div class="mt-14 grid md:grid-cols-12 gap-8 md:gap-10 items-center">
      <div class="md:col-span-5">
        <div class="relative">
          <div class="absolute -inset-3 rounded-[28px] bg-gradient-to-br from-brand-200/60 to-brand-100/30 -rotate-2" aria-hidden="true"></div>
          <Image
            src={mulherImg}
            alt={howItWorks.leftImageAlt}
            widths={[320, 480, 640, 800]}
            sizes="(min-width: 768px) 420px, 90vw"
            formats={['avif', 'webp']}
            quality={82}
            loading="lazy"
            class="relative w-full h-auto rounded-3xl shadow-soft object-cover"
          />
        </div>
      </div>

      <ol class="md:col-span-7 space-y-5">
        {howItWorks.steps.map((step) => (
          <li class="flex gap-5 rounded-2xl bg-brand-50/40 border border-brand-100 p-5 md:p-6">
            <span class="shrink-0 w-14 h-14 rounded-2xl bg-brand-600 text-white grid place-items-center font-black text-xl shadow-soft">
              {step.n}
            </span>
            <div>
              <h3 class="text-lg md:text-xl font-extrabold text-ink leading-snug">{step.title}</h3>
              <p class="mt-2 text-[15px] md:text-base text-ink/75 leading-relaxed">{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <figure class="mt-14 max-w-3xl mx-auto rounded-3xl overflow-hidden shadow-glow border border-brand-100">
      <Image
        src={resultImg}
        alt={howItWorks.rightImageAlt}
        widths={[480, 720, 960]}
        sizes="(min-width: 768px) 720px, 100vw"
        formats={['avif', 'webp']}
        quality={82}
        loading="lazy"
        class="w-full h-auto"
      />
    </figure>
  </div>
</section>
