---
// src/components/Features.astro
import { copy } from "../lib/copy.js";
const { features } = copy;
---
<section class="bg-white py-16 md:py-24 px-4 md:px-6" aria-labelledby="features-heading">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto">
      <p class="uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-3">
        {features.eyebrow}
      </p>
      <h2 id="features-heading" class="text-3xl md:text-5xl font-black leading-tight text-balance text-ink">
        {features.headline}
      </h2>
      <p class="mt-4 text-base md:text-lg text-ink/70">{features.subheadline}</p>
    </div>

    <ol class="mt-14 grid md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {features.items.map((item) => (
        <li class="relative rounded-3xl bg-gradient-to-br from-brand-50/80 to-white border border-brand-100 p-7 hover:shadow-soft transition-shadow">
          <span class="absolute -top-4 left-7 inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-brand-600 text-white font-black text-lg shadow-soft">
            {item.n}
          </span>
          <h3 class="mt-4 text-xl font-extrabold text-ink leading-snug">{item.title}</h3>
          <p class="mt-3 text-[15px] text-ink/70 leading-relaxed">{item.desc}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
