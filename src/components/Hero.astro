---
// src/components/Hero.astro
import { copy } from "../lib/copy.js";
import { Image, getImage } from "astro:assets";
import heroImg from "../assets/hero-mockup.webp";

const { hero } = copy;

const heroPicture = await getImage({
  src: heroImg,
  widths: [480, 720, 960, 1280],
  formats: ['webp'],
});
---
<link
  slot="head"
  rel="preload"
  as="image"
  href={heroPicture.src}
  imagesrcset={heroPicture.srcSet.attribute}
  imagesizes="(min-width: 1024px) 50vw, 100vw"
  fetchpriority="high"
/>

<section
  class="relative overflow-hidden bg-gradient-to-b from-brand-50 via-cream to-cream pt-6 pb-16 md:pt-10 md:pb-24"
  aria-labelledby="hero-heading"
>
  {/* Banner superior */}
  <div class="bg-brand-700 text-white text-center text-[12px] md:text-sm font-semibold tracking-wide px-4 py-2.5 absolute top-0 inset-x-0">
    <span class="inline-block animate-pulse-soft">●</span>
    <span class="ml-2">{hero.banner}</span>
  </div>

  <div class="mx-auto max-w-6xl px-4 md:px-6 pt-12 md:pt-16">
    <div class="grid md:grid-cols-2 gap-10 md:gap-14 items-center">
      {/* Columna texto */}
      <div class="order-2 md:order-1 text-center md:text-left">
        <p class="inline-block uppercase tracking-[0.2em] text-[11px] md:text-xs font-semibold text-brand-700 bg-brand-100/60 rounded-full px-3 py-1 mb-5">
          {hero.eyebrow}
        </p>
        <h1
          id="hero-heading"
          class="text-4xl md:text-6xl font-black leading-[1.05] tracking-tight text-balance text-ink"
        >
          {hero.headline.line1}
          <span class="block text-brand-600">{hero.headline.highlight}</span>
          {hero.headline.line2}
        </h1>
        <p class="mt-6 text-base md:text-lg leading-relaxed text-ink/75 max-w-xl mx-auto md:mx-0">
          {hero.subheadline}
        </p>

        <ul class="mt-7 space-y-3 max-w-md mx-auto md:mx-0">
          {hero.bullets.map((b) => (
            <li class="flex items-start gap-3 text-[15px] md:text-base text-ink/80">
              <svg class="shrink-0 w-5 h-5 mt-0.5 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12l5 5L20 7" />
              </svg>
              <span>{b}</span>
            </li>
          ))}
        </ul>

        {/* Timer */}
        <div class="mt-8 inline-flex items-center gap-3 bg-white/70 backdrop-blur border border-brand-100 rounded-2xl px-4 py-3 shadow-soft">
          <span class="text-[11px] uppercase tracking-wider text-ink/60 font-semibold">{hero.timerNote}</span>
          <div id="hero-timer" class="flex items-center gap-2 font-mono font-bold text-brand-700 text-base md:text-lg" aria-live="polite">
            <span data-unit="hours">00</span><span>:</span>
            <span data-unit="minutes">00</span><span>:</span>
            <span data-unit="seconds">00</span>
          </div>
        </div>

        <div class="mt-8 flex flex-col items-center md:items-start gap-3">
          <a
            href="#final-cta-section"
            class="inline-flex items-center justify-center bg-brand-600 hover:bg-brand-700 text-white font-bold py-5 px-8 md:px-10 rounded-2xl shadow-glow text-base md:text-lg uppercase tracking-wide transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-300"
          >
            {hero.cta}
            <svg class="ml-2 w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
          <p class="text-xs text-ink/60 flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
            {hero.secondaryNote}
          </p>
        </div>
      </div>

      {/* Columna imagen */}
      <div class="order-1 md:order-2 relative">
        <div class="absolute -inset-6 bg-gradient-to-tr from-brand-200/40 via-transparent to-brand-100/40 blur-3xl rounded-full" aria-hidden="true"></div>
        <div class="relative">
          <Image
            src={heroImg}
            alt={hero.imageAlt}
            widths={[320, 480, 720, 960]}
            sizes="(min-width: 768px) 480px, 90vw"
            formats={['avif', 'webp']}
            quality={82}
            loading="eager"
            fetchpriority="high"
            class="w-full max-w-md mx-auto h-auto drop-shadow-2xl"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const timer = document.getElementById("hero-timer");
    if (!timer) return;
    const pad = (n) => String(n).padStart(2, "0");
    const target = new Date();
    target.setHours(23, 59, 59, 999);

    function tick() {
      const now = new Date();
      let diff = Math.max(0, target.getTime() - now.getTime());
      const h = Math.floor(diff / 3600000); diff %= 3600000;
      const m = Math.floor(diff / 60000); diff %= 60000;
      const s = Math.floor(diff / 1000);
      timer.querySelector('[data-unit="hours"]').textContent = pad(h);
      timer.querySelector('[data-unit="minutes"]').textContent = pad(m);
      timer.querySelector('[data-unit="seconds"]').textContent = pad(s);
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>
