---
// src/components/Story.astro
import { copy } from "../lib/copy.js";
import { Image } from "astro:assets";
import scienceImg from "../assets/comprovacao-cientifica.webp";
import industryImg from "../assets/industria.webp";

const { story } = copy;
---
<section class="bg-white py-16 md:py-24 px-4 md:px-6" aria-labelledby="story-heading">
  <div class="mx-auto max-w-5xl">
    <p class="text-center uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-4">
      {story.eyebrow}
    </p>
    <h2
      id="story-heading"
      class="text-center text-3xl md:text-5xl font-black leading-tight text-balance text-ink"
    >
      {story.headline}
    </h2>

    <div class="mt-12 grid md:grid-cols-12 gap-8 md:gap-10 items-center">
      <div class="md:col-span-5">
        <div class="relative">
          <div class="absolute -inset-3 rounded-[28px] bg-brand-100/60 rotate-2" aria-hidden="true"></div>
          <Image
            src={industryImg}
            alt={story.industryImageAlt}
            widths={[320, 480, 640]}
            sizes="(min-width: 768px) 420px, 90vw"
            formats={['avif', 'webp']}
            quality={82}
            loading="lazy"
            class="relative w-full h-auto rounded-3xl shadow-soft object-cover"
          />
        </div>
      </div>

      <div class="md:col-span-7 space-y-5 text-[17px] md:text-lg leading-relaxed text-ink/80">
        {story.paragraphs.map((p, i) => (
          <p class={i === 0 ? "first-letter:text-5xl first-letter:font-black first-letter:text-brand-600 first-letter:mr-2 first-letter:float-left first-letter:leading-none" : ""}>
            {p}
          </p>
        ))}
      </div>
    </div>

    <figure class="mt-12 rounded-3xl overflow-hidden shadow-soft border border-brand-100/60 max-w-3xl mx-auto">
      <Image
        src={scienceImg}
        alt={story.scienceImageAlt}
        widths={[480, 768, 1024]}
        sizes="(min-width: 768px) 768px, 100vw"
        formats={['avif', 'webp']}
        quality={82}
        loading="lazy"
        class="w-full h-auto"
      />
    </figure>

    <div class="mt-10 grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {story.highlights.map((h) => (
        <div class="rounded-2xl bg-brand-50/60 border border-brand-100 p-5 text-center">
          <p class="text-3xl md:text-4xl font-black text-brand-700 leading-none">{h.value}</p>
          <p class="mt-2 text-sm text-ink/70">{h.label}</p>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href="#final-cta-section"
        class="inline-block bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-2xl shadow-soft uppercase tracking-wide text-sm md:text-base transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-300"
      >
        {story.cta}
      </a>
    </div>
  </div>
</section>
