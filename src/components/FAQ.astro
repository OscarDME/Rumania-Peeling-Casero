---
// src/components/FAQ.astro
import { copy } from "../lib/copy.js";
const { faq } = copy;
---
<section class="bg-cream py-16 md:py-24 px-4 md:px-6" aria-labelledby="faq-heading">
  <div class="mx-auto max-w-3xl">
    <div class="text-center">
      <p class="uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-3">
        {faq.eyebrow}
      </p>
      <h2 id="faq-heading" class="text-3xl md:text-5xl font-black leading-tight text-balance text-ink">
        {faq.headline}
      </h2>
    </div>

    <div class="mt-12 divide-y divide-brand-100 rounded-3xl bg-white border border-brand-100 shadow-soft">
      {faq.items.map((item) => (
        <details class="group p-5 md:p-6">
          <summary class="flex items-center justify-between gap-4 cursor-pointer list-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-300 rounded-lg">
            <h3 class="text-base md:text-lg font-bold text-ink leading-snug">{item.q}</h3>
            <span class="shrink-0 w-9 h-9 rounded-full bg-brand-50 text-brand-700 grid place-items-center transition-transform group-open:rotate-45">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 text-[15px] md:text-base text-ink/75 leading-relaxed">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
