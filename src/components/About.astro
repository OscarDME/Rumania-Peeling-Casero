---
// src/components/About.astro
import { copy } from "../lib/copy.js";
import { Image } from "astro:assets";
import patriciaImg from "../assets/patricia-elias.webp";

const { about } = copy;
---
<section class="bg-white py-16 md:py-24 px-4 md:px-6" aria-labelledby="about-heading">
  <div class="mx-auto max-w-6xl">
    <div class="grid md:grid-cols-5 gap-10 md:gap-12 items-center">
      <div class="md:col-span-2">
        <div class="relative">
          <div class="absolute -inset-4 bg-brand-100/50 rounded-[28px] -rotate-3" aria-hidden="true"></div>
          <Image
            src={patriciaImg}
            alt={about.photoAlt}
            widths={[320, 480, 640]}
            sizes="(min-width: 768px) 380px, 80vw"
            formats={['avif', 'webp']}
            quality={82}
            loading="lazy"
            class="relative w-full max-w-sm mx-auto h-auto rounded-3xl shadow-soft"
          />
        </div>
      </div>
      <div class="md:col-span-3">
        <p class="uppercase tracking-[0.25em] text-xs font-semibold text-brand-600 mb-3">
          {about.eyebrow}
        </p>
        <h2 id="about-heading" class="text-3xl md:text-5xl font-black leading-tight text-ink">
          {about.title}
        </h2>
        <p class="mt-2 text-xl md:text-2xl font-bold text-brand-700">{about.name}</p>

        <div class="mt-6 space-y-4 text-[16px] md:text-lg text-ink/75 leading-relaxed">
          {about.paragraphs.map((p) => <p>{p}</p>)}
        </div>

        <ul class="mt-8 grid sm:grid-cols-3 gap-3">
          {about.stats.map((s) => (
            <li class="rounded-2xl bg-brand-50/60 border border-brand-100 p-4 text-center">
              <p class="text-2xl md:text-3xl font-black text-brand-700 leading-none">{s.value}</p>
              <p class="mt-1 text-xs text-ink/70">{s.label}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
