---
// src/layouts/Layout.astro
import "../styles/globals.css";

import "@fontsource/poppins/100.css";
import "@fontsource/poppins/200.css";
import "@fontsource/poppins/300.css";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";
import "@fontsource/poppins/800.css";
import "@fontsource/poppins/900.css";

import { copy } from "../lib/copy.js";
import FacebookPixel from "../components/FacebookPixel.astro";
import HotmartSrcListener from "../components/HotmartSrcListener.astro";

const { metadata } = copy;
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <link rel="canonical" href={Astro.url.href} />

    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='50' fill='%23df4d6c'/></svg>"
    />

    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <slot name="head" />

    <FacebookPixel />

    <script is:inline>
      (function () {
        function stripHash() {
          if (location.hash) {
            history.replaceState(null, "", location.pathname + location.search);
          }
        }
        stripHash();
        window.addEventListener("hashchange", function () { stripHash(); });
        var _replaceState = history.replaceState;
        history.replaceState = function (state, title, url) {
          try {
            if (typeof url === "string" && url.indexOf("#") !== -1) {
              url = url.split("#")[0];
            }
          } catch (e) {}
          return _replaceState.call(history, state, title, url);
        };
        var _pushState = history.pushState;
        history.pushState = function (state, title, url) {
          try {
            if (typeof url === "string" && url.indexOf("#") !== -1) {
              url = url.split("#")[0];
            }
          } catch (e) {}
          return _pushState.call(history, state, title, url);
        };
        var tries = 0;
        var t = setInterval(function () {
          stripHash();
          tries++;
          if (tries > 200) clearInterval(t);
        }, 50);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-cream text-ink antialiased font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:ring-2 focus:ring-brand-500"
    >
      {copy.a11y.skipToContent}
    </a>

    <HotmartSrcListener />

    <slot />
  </body>
</html>
